# Production secrets — copy to .env.production (gitignored; SOPS/age-encrypted
# at rest, decrypted on the host at deploy time). The production overlay
# refuses to boot if POSTGRES_PASSWORD or JWT_KEYS_DIR are unset.
POSTGRES_USER=rl
POSTGRES_PASSWORD=
POSTGRES_DB=resilient_learn
TAG=
JWT_KEYS_DIR=
FRONTEND_PORT=80
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
