# Production secrets — copy to .env.production (gitignored; SOPS/age-encrypted
# at rest, decrypted on the host at deploy time). The production overlay
# refuses to boot if POSTGRES_PASSWORD or JWT_KEYS_DIR are unset.
POSTGRES_USER=rl
POSTGRES_PASSWORD=
POSTGRES_DB=resilient_learn
TAG=
JWT_KEYS_DIR=
FRONTEND_PORT=80
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Delivery channel for phone-OTP activation codes. Never `mock` in production —
# it logs codes and delivers none. `usapp` requires USAPP_BASE_URL + USAPP_API_KEY;
# `http` requires SMS_HTTP_URL + SMS_HTTP_API_KEY. The backend refuses to boot
# when the chosen driver's credentials are missing.
OTP_DELIVERY_DRIVER=usapp
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
USAPP_BASE_URL=
USAPP_API_KEY=
USAPP_TIMEOUT_MS=5000
# First-run bootstrap (docker compose ... --profile bootstrap run --rm bootstrap)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PHONE=