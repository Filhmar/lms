# Production secrets — copy to .env.production (gitignored; SOPS/age-encrypted
# at rest, decrypted on the host at deploy time). The production overlay
# refuses to boot if POSTGRES_PASSWORD or JWT_KEYS_DIR are unset.
POSTGRES_USER=rl
POSTGRES_PASSWORD=
POSTGRES_DB=resilient_learn
TAG=
JWT_KEYS_DIR=
FRONTEND_PORT=80
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Phone-OTP activation SMS: http gateway strongly recommended in production
# (mock only logs codes). SMS_HTTP_URL/KEY are required when SMS_DRIVER=http.
SMS_DRIVER=http
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
# First-run bootstrap (docker compose ... --profile bootstrap run --rm bootstrap)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PHONE=
