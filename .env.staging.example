# Staging secrets — copy to .env.staging (gitignored; keep SOPS/age-encrypted
# at rest per the delivery blueprint) and fill in real values.
POSTGRES_USER=rl
POSTGRES_PASSWORD=CHANGE_ME_STAGING
POSTGRES_DB=resilient_learn
TAG=staging
JWT_KEYS_DIR=/etc/resilient-learn/keys
FRONTEND_PORT=8080
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STAGING
# Phone-OTP activation SMS: mock (logs codes, no real SMS) or http gateway.
SMS_DRIVER=mock
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
# First-run bootstrap (docker compose ... --profile bootstrap run --rm bootstrap)
BOOTSTRAP_ADMIN_EMAIL=admin@example.gov.ph
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STAGING
BOOTSTRAP_ADMIN_NAME=Central Administrator
BOOTSTRAP_ADMIN_PHONE=09170000000
