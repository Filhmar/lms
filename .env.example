# Compose variables (base + overlays). Copy to .env for local development —
# every value has a safe dev default; staging/production use their own files.

# Postgres
POSTGRES_USER=rl
POSTGRES_PASSWORD=rl_dev_password
POSTGRES_DB=resilient_learn

# Image tag applied to rl-backend / rl-frontend / rl-migrate
TAG=local

# Directory with jwt-private.pem / jwt-public.pem, mounted read-only into the
# backend (dev: generated by backend/scripts/gen-dev-keys.sh)
JWT_KEYS_DIR=./backend/.keys

# Published ports (overlay-dependent defaults: dev 3000, staging 8080, prod 80)
FRONTEND_PORT=3000

# Monitoring overlay
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Phone-OTP delivery (consumed by docker-compose.yml x-backend-env).
# mock = log the code; http = SMS gateway; usapp = Usapp tenant API.
OTP_DELIVERY_DRIVER=mock
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
USAPP_BASE_URL=
USAPP_API_KEY=
USAPP_TIMEOUT_MS=5000