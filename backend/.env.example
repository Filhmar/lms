# Resilient-Learn backend — local development env.
# No localhost defaults ship in containers; every value here is dev-only.
NODE_ENV=development
PORT=3200

# Local dev services (started by scripts/dev-services.sh)
DATABASE_URL=postgresql://rl@localhost:55432/resilient_learn
REDIS_URL=redis://localhost:56379

# RS256 keypair for JWT signing (generated by scripts/gen-dev-keys.sh)
JWT_PRIVATE_KEY_PATH=.keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=.keys/jwt-public.pem

# ObjectStorage local-fs driver root (S3/Azure drivers come later per TECHSTACK)
STORAGE_DIR=.storage

# Token lifetimes (seconds): 15 min access / 7 day refresh
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800

# prom-client standalone /metrics server (0 = disabled; containers set 9464)
METRICS_PORT=0

# SMS driver for phone-OTP activation: mock logs the code (and surfaces it as
# devCode in development); http POSTs {to,message} to SMS_HTTP_URL with a
# Bearer SMS_HTTP_API_KEY (both required when SMS_DRIVER=http).
SMS_DRIVER=mock
