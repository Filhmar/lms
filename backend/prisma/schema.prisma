// Resilient-Learn Phase I–III schema — one PostgreSQL database, schema-per-module
// ownership (auth.*, org.*, prov.*, cbt.*, courses.*). Fully qualify these
// tables in raw SQL.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

// Connection URL lives in prisma.config.ts (migrate) and the PrismaPg driver
// adapter (runtime) — Prisma 7 removed `url` from schema files.
datasource db {
  provider = "postgresql"
  schemas  = ["auth", "org", "prov", "cbt", "courses"]
}

/* --------------------------------- org ---------------------------------- */

enum ScopeLevel {
  central
  region
  division
  district
  school

  @@map("scope_level")
  @@schema("org")
}

model Scope {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  level     ScopeLevel
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  descendants ScopeHierarchy[] @relation("ancestor")
  ancestors   ScopeHierarchy[] @relation("descendant")
  users       User[]
  exams       Exam[]
  courses     Course[]

  @@map("scopes")
  @@schema("org")
}

/// Closure table: every ancestor/descendant pair, incl. self-rows (depth 0).
/// Subtree + breadcrumb become single non-recursive index scans.
model ScopeHierarchy {
  ancestorId   String @map("ancestor_id") @db.Uuid
  descendantId String @map("descendant_id") @db.Uuid
  depth        Int

  ancestor   Scope @relation("ancestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Scope @relation("descendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  // Reverse covering index: breadcrumb ("all ancestors of X") walks descendant → ancestor.
  @@index([descendantId, ancestorId])
  @@map("scope_hierarchy")
  @@schema("org")
}

/* --------------------------------- auth --------------------------------- */

enum UserRole {
  student
  teacher
  school_admin
  district_admin
  division_admin
  region_admin
  central_admin

  @@map("user_role")
  @@schema("auth")
}

enum UserStatus {
  pending_activation
  active
  disabled

  @@map("user_status")
  @@schema("auth")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  fullName     String     @map("full_name")
  role         UserRole
  scopeId      String     @map("scope_id") @db.Uuid
  status       UserStatus @default(pending_activation)
  passwordHash String?    @map("password_hash")
  /// E.164 Philippine mobile (+639XXXXXXXXX). Deliberately NOT unique —
  /// siblings may share a guardian's phone.
  phone        String?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  scope          Scope            @relation(fields: [scopeId], references: [id])
  refreshTokens  RefreshToken[]
  otpRequests    OtpRequest[]
  attempts       Attempt[]
  courseProgress CourseProgress[]

  @@index([phone])
  @@map("users")
  @@schema("auth")
}

/// Phone-OTP activation codes (Usapp-style). Only the sha256 hex of the
/// 6-digit code is stored; rows are superseded (consumed) by newer requests.
model OtpRequest {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  phone      String
  purpose    String    @default("activation")
  /// sha256 hex of the 6-digit code — the raw code is never stored.
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt])
  @@map("otp_requests")
  @@schema("auth")
}

/// The ONLY stateful auth artifact (stateless JWT everywhere else — never a
/// session table). Rows are touched only on refresh/logout.
model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  /// sha256 hex of the opaque token — the raw token is never stored.
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  /// Rotation chain: id of the token that superseded this one (reuse detection).
  replacedBy String?   @map("replaced_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
  @@schema("auth")
}

/* --------------------------------- prov --------------------------------- */

enum JobStatus {
  queued
  processing
  completed
  failed

  @@map("job_status")
  @@schema("prov")
}

/// Source of truth for job state (BullMQ is transport only — a Redis failover
/// must never lose import state).
model ProvisioningJob {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind          String    @default("bulk_import")
  status        JobStatus @default(queued)
  targetScopeId String    @map("target_scope_id") @db.Uuid
  filePath      String    @map("file_path")
  total         Int       @default(0)
  success       Int       @default(0)
  failed        Int       @default(0)
  /// [{ row, reason }]
  errors        Json      @default("[]")
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("jobs")
  @@schema("prov")
}

/* --------------------------------- cbt ---------------------------------- */

/// Phase II computer-based testing. Visibility follows downward inheritance:
/// an exam owned by an ancestor scope is visible to every descendant scope
/// (join on org.scope_hierarchy); siblings are laterally isolated.
model Exam {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  ownerScopeId    String   @map("owner_scope_id") @db.Uuid
  /// 'draft' | 'published' (CHECK-constrained in the migration).
  status          String   @default("draft")
  version         Int      @default(1)
  durationMinutes Int      @map("duration_minutes")
  opensAt         DateTime @map("opens_at") @db.Timestamptz(6)
  closesAt        DateTime @map("closes_at") @db.Timestamptz(6)
  /// Versioned per examination (exam_v1 ↔ public_key_v1) so a compromised
  /// key never exposes exam history.
  keyVersion      Int      @default(1) @map("key_version")
  publicKeyPem    String   @map("public_key_pem")
  /// ⚠️ DEV-GRADE KEY CUSTODY ⚠️ — the per-exam RSA private key sits in the
  /// database in PLAINTEXT. Production custody is a KMS (Azure Key Vault /
  /// AWS KMS / Vault) behind the KeyProvider port (driver 'db' today); the
  /// key must then never leave the KMS. Never expose this column through any
  /// API response or log.
  privateKeyPem   String   @map("private_key_pem")
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ownerScope Scope      @relation(fields: [ownerScopeId], references: [id])
  questions  Question[]
  attempts   Attempt[]

  @@index([ownerScopeId, status])
  @@map("exams")
  @@schema("cbt")
}

model Question {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId String @map("exam_id") @db.Uuid
  seq    Int
  /// 'mcq' | 'tf' | 'ident' (CHECK-constrained in the migration).
  type   String
  text   String
  /// [{ id, text }] for mcq/tf; null for ident.
  options Json?
  /// mcq/tf: the correct option id (string). ident: array of accepted
  /// strings, matched case/whitespace-insensitively. NEVER serialized into
  /// any API response — package/list queries must not select this column.
  correct Json
  weight  Int  @default(1)

  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([examId, seq])
  @@map("questions")
  @@schema("cbt")
}

/// One attempt per exam per student (PRD "one attempt") — UNIQUE(exam, user).
model Attempt {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId               String    @map("exam_id") @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  /// 'in_progress' | 'submitted' | 'grading' | 'graded' (CHECK in migration).
  state                String    @default("in_progress")
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  /// Server-anchored wall-clock deadline: started + duration, capped at closes_at.
  deadlineAt           DateTime  @map("deadline_at") @db.Timestamptz(6)
  submittedAt          DateTime? @map("submitted_at") @db.Timestamptz(6)
  answeredCountClaimed Int?      @map("answered_count_claimed")
  scoreRaw             Int?      @map("score_raw")
  scoreTotal           Int?      @map("score_total")
  gradedAt             DateTime? @map("graded_at") @db.Timestamptz(6)

  exam    Exam     @relation(fields: [examId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  answers Answer[]

  @@unique([examId, userId])
  @@index([userId])
  @@map("attempts")
  @@schema("cbt")
}

/// LWW-Element-Set answer state — merged by ONE atomic ON CONFLICT upsert
/// (TECHSTACK §5.3): keep the higher client_ts; server stamps received_at;
/// client_ts is advisory within the server-validated attempt window.
/// Partitioning by exam window (archive to object storage after grading) is
/// the documented scale valve — DEFERRED until national-scale load demands
/// it; today one table with the composite PK index is plenty.
model Answer {
  attemptId  String   @map("attempt_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  /// EncryptedEnvelope { alg: 'RSA-OAEP-256+A256GCM', keyVersion, wrappedKey, iv, ciphertext }
  /// — envelope-encrypted CLIENT-side; the server stores ciphertext only and
  /// decrypts solely in the grading worker via the KeyProvider.
  envelope   Json
  clientTs   BigInt   @map("client_ts")
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  /// Client-generated idempotency key: replayed answer events dedupe here.
  eventId    String   @unique @map("event_id") @db.Uuid

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@id([attemptId, questionId])
  @@map("answers")
  @@schema("cbt")
}

/// Thin idempotency ledger + audit trail for sync events. Submit events
/// dedupe against this table; answer events dedupe via answers.event_id too.
/// attempt_id is deliberately un-FK'd — rejected events may reference
/// attempts that don't exist.
model SyncEventRecord {
  eventId    String   @id @map("event_id") @db.Uuid
  kind       String
  attemptId  String   @map("attempt_id") @db.Uuid
  outcome    String
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@index([attemptId])
  @@map("sync_events")
  @@schema("cbt")
}

/* ------------------------------- courses -------------------------------- */

/// Phase III headless course. Same visibility rule as cbt.exams: downward
/// inheritance via org.scope_hierarchy (a course owned by an ancestor scope
/// is visible to every descendant scope; siblings are laterally isolated).
model Course {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  subject      String
  ownerScopeId String   @map("owner_scope_id") @db.Uuid
  /// 'draft' | 'published' (CHECK-constrained in the migration).
  status       String   @default("draft")
  version      Int      @default(1)
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ownerScope Scope            @relation(fields: [ownerScopeId], references: [id])
  chapters   Chapter[]
  progress   CourseProgress[]

  @@index([ownerScopeId, status])
  @@map("courses")
  @@schema("courses")
}

model Chapter {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId String @map("course_id") @db.Uuid
  seq      Int
  title    String

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  pages  CoursePage[]

  @@unique([courseId, seq])
  @@map("chapters")
  @@schema("courses")
}

/// Headless page — pure data behind the PWA's type switch. Shape-per-type is
/// CHECK-constrained in the migration: text_content ⇒ body (markdown);
/// video ⇒ video_* triple; assessment_embed ⇒ exam_id.
model CoursePage {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId String @map("chapter_id") @db.Uuid
  seq       Int
  /// 'text_content' | 'video' | 'assessment_embed' (CHECK in migration).
  type      String
  title     String
  /// Markdown body for text_content pages.
  body      String?
  /// ObjectStorage basename under courses/<course_id>/ — served via
  /// GET /api/v1/courses/:id/assets/:key (never a raw filesystem path).
  videoAssetKey      String? @map("video_asset_key")
  videoSizeBytes     BigInt? @map("video_size_bytes")
  videoDurationLabel String? @map("video_duration_label")
  /// References cbt.exams — deliberately NOT a cross-schema FK (module seam);
  /// validated on write instead (seed today; authoring API later).
  examId             String? @map("exam_id") @db.Uuid

  chapter  Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress CourseProgress[]

  @@unique([chapterId, seq])
  @@map("pages")
  @@schema("courses")
}

/// LWW-Element-Set reading progress ("page completed") — identical merge
/// shape to cbt.answers: keyed (user_id, page_id), one atomic ON CONFLICT
/// upsert keeps the higher client_ts; server stamps received_at; event_id is
/// the client idempotency key.
model CourseProgress {
  userId     String   @map("user_id") @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  pageId     String   @map("page_id") @db.Uuid
  clientTs   BigInt   @map("client_ts")
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  eventId    String   @unique @map("event_id") @db.Uuid

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  page   CoursePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([userId, pageId])
  // Covers the per-course completed count and GET /courses/:id/progress.
  @@index([userId, courseId])
  @@map("progress")
  @@schema("courses")
}
